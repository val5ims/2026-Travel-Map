{
    "name": "DRR & DRI Travel Dashboard Theme",
    "dataColors": [
        "#2E86C1",
        "#27AE60",
        "#F39C12",
        "#E74C3C",
        "#8E44AD"
    ],
    "background": "#FFFFFF",
    "foreground": "#2C3E50",
    "tableAccent": "#2E86C1",
    "visualStyles": {
        "*": {
            "*": {
                "title": [
                    {
                        "fontFamily": "Segoe UI Semibold",
                        "fontSize": 14,
                        "color": {
                            "solid": {
                                "color": "#2C3E50"
                            }
                        }
                    }
                ],
                "labels": [
                    {
                        "color": {
                            "solid": {
                                "color": "#2C3E50"
                            }
                        }
                    }
                ]
            }
        },
        "card": {
            "*": {
                "labels": [
                    {
                        "fontSize": 24
                    }
                ],
                "categoryLabels": [
                    {
                        "fontSize": 12
                    }
                ]
            }
        }
    }
}